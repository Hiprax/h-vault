# =============================================================================
# H-Vault — configuration
# =============================================================================
# Copy to `.env` and fill in the values below:  cp .env.example .env
#
# This ONE file configures everything. There is no per-package .env: the Docker
# stack hands this whole file to the app container (`env_file: .env` in
# docker-compose.yml), and outside Docker the server resolves it from the monorepo
# root. Compose also reads it for its own ${...} substitutions (the published port,
# the MongoDB credentials).
#
# A handful of keys below are IGNORED when running under Docker Compose, because
# the container topology fixes them and .env cannot know them. Compose overrides
# each one, and every such key is marked "[docker: overridden]" here:
#
#     NODE_ENV        -> always production in the stack
#     PORT            -> always 5000 inside the app container (never published)
#     MONGODB_URI     -> always points at the in-stack `hvault-db` replica set
#     TRUST_PROXY     -> set from TRUST_PROXY_HOPS (see below)
#
# Generate every secret with:
#     node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

# -----------------------------------------------------------------------------
# Docker Compose  (only read when deploying with `docker compose up`)
# -----------------------------------------------------------------------------
# The ONE host port the whole stack publishes, bound to 127.0.0.1. Your system
# Nginx terminates TLS and proxies to it — see docker/nginx/system.docker.example.conf,
# and keep its `proxy_pass` in sync with whatever you set here.
#
# If this host runs more than one of these stacks, EVERY stack needs its own port
# (they all bind 127.0.0.1, so a duplicate is a bind conflict), its own subnets
# (below), and its own HVAULT_STACK_NAME (immediately below).
HVAULT_HTTP_PORT=8080

# Namespaces the whole stack: the Compose project, and with it every container,
# network and volume name. Leave it alone unless this host runs a SECOND H-Vault —
# in which case give that one its own name, because two stacks sharing a project name
# do not fail loudly. Compose considers them the same project, so the second `up`
# recreates the first one's containers and adopts its volumes.
HVAULT_STACK_NAME=hvault

# How many reverse proxies sit in front of Express. This MUST match reality exactly:
# Express trusts the last N entries of X-Forwarded-For, so too high lets a client
# spoof its own IP (defeating the IP-keyed rate limits and poisoning the audit log),
# and too low attributes every request to the proxy.
#   2 = your system Nginx + the stack's internal Nginx   <- the documented setup
#   1 = you expose 127.0.0.1:${HVAULT_HTTP_PORT} directly, with no system Nginx
TRUST_PROXY_HOPS=2

# The two bridge subnets the stack pins (edge = Nginx <-> app + the app's egress;
# data = app <-> MongoDB, with no route off the host). They are pinned so the
# addresses cannot drift with whatever else exists on the host that day.
#
# Change them if 172.28.x is already taken here — a collision is not a warning:
# Docker refuses to create the network ("Pool overlaps with other one on this
# address space") and the stack will not start. `docker network ls` and
# `docker network inspect <name>` show what is in use. Keep the two distinct.
HVAULT_EDGE_SUBNET=172.28.0.0/24
HVAULT_DATA_SUBNET=172.28.1.0/24

# The tag the stack's own images are built and run under. Keep it equal to the
# `version` in package.json (a unit test asserts the compose default does), so a
# rollback is `git checkout v<previous> && docker compose up -d --build`: the old
# release's images are still on the host under their own tag, and `docker compose
# ps` says out loud which release is serving.
HVAULT_VERSION=0.1.0

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=5000                              # [docker: overridden -> 5000, unpublished]
NODE_ENV=development                   # [docker: overridden -> production]
APP_NAME=H-Vault

# ---- CHANGE THESE TWO TO YOUR OWN DOMAIN BEFORE DEPLOYING --------------------
# Your public URL. It goes into the links H-Vault emails (verification, password
# reset, account unlock), so it must be an address a user's browser can reach.
APP_URL=https://vault.example.com

# Browser origin allowed to call the API. In production the app REFUSES TO BOOT
# unless this is https:// — deliberately, so a misconfigured deployment fails loudly
# instead of quietly running with a permissive origin. Behind the single-port stack
# the SPA and the API share an origin, so this is simply your public URL again.
#
# The https:// default above is correct for BOTH modes, which is why it is not the
# localhost value you might expect: under Docker, Compose pins NODE_ENV=production,
# so an http:// value here is a hard boot failure; and for local `npm run dev` this
# value is never exercised, because the Vite dev server proxies /api to Express
# same-origin and the browser therefore performs no CORS check at all.
CORS_ORIGIN=https://vault.example.com

# -----------------------------------------------------------------------------
# MongoDB
# -----------------------------------------------------------------------------
# Local (non-Docker) connection string.        [docker: overridden -> hvault-db/rs0]
MONGODB_URI=mongodb://localhost:27017/hvault

# Credentials for the database INSIDE the Docker stack. Compose creates the root
# user from these on first boot and interpolates them into the app's MONGODB_URI.
#
# IMPORTANT: the password is embedded in a connection URI, so keep it URL-SAFE.
# A raw '@', ':', '/', '?' or '#' would be parsed as URI syntax and the app would
# fail to connect. Generate it with:  openssl rand -hex 32
#
# Also note it is only applied on the FIRST boot against an empty data directory —
# changing it later does not rotate the existing user (see the README's
# troubleshooting table for how to rotate it properly).
#
# It is deliberately left EMPTY here rather than carrying a placeholder value. A
# placeholder is a working password: `cp .env.example .env`, fill in the secrets that
# shout at you, and you would be running a password manager whose database root
# credential is a literal published in this repository — with nothing to tell you.
# Empty fails closed instead: `docker compose up` stops immediately with
# "MONGO_ROOT_PASSWORD is required" (the `:?` guard in docker-compose.yml), because
# `${VAR:?}` rejects an empty value exactly as it rejects a missing one.
MONGO_ROOT_USERNAME=hvault
MONGO_ROOT_PASSWORD=

MONGO_MAX_POOL_SIZE=10
MONGO_MIN_POOL_SIZE=2

# -----------------------------------------------------------------------------
# JWT — minimum 32 characters each, and they must differ from one another
# -----------------------------------------------------------------------------
# The placeholders below deliberately start with `dev-`, which the server REFUSES
# to boot with outside development. That is the point: `cp .env.example .env` and
# forgetting to change them would otherwise run a password manager on signing keys
# that are published in this repository, and nothing else would complain — they are
# over 32 characters, so validation alone would pass them.
JWT_ACCESS_SECRET=dev-replace-with-unique-access-token-secret-at-least-32-chars
JWT_REFRESH_SECRET=dev-replace-with-different-refresh-token-secret-at-least-32-chars
JWT_ACCESS_EXPIRY=5m
JWT_REFRESH_EXPIRY=7d

# -----------------------------------------------------------------------------
# Security
# -----------------------------------------------------------------------------
BCRYPT_ROUNDS=12

# Minimum 32 characters. Signs the CSRF double-submit token.
SESSION_SECRET=dev-replace-me-with-secure-random-32-chars

# Optional (min 32 chars). Encrypts the stored 2FA TOTP secrets. Falls back to
# SESSION_SECRET; set a dedicated key in production so the CSRF and 2FA keys are
# separated.
# TWO_FACTOR_ENCRYPTION_KEY=

# Reverse-proxy hop count for Express. Leave EMPTY outside Docker unless you run
# behind a proxy; under Docker it is set from TRUST_PROXY_HOPS above.
# TRUST_PROXY=                         # [docker: overridden -> TRUST_PROXY_HOPS]

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# -----------------------------------------------------------------------------
# Email — required for verification, password reset, account unlock and backups
# -----------------------------------------------------------------------------
# Provider: "smtp" (default) or "gmail".
EMAIL_PROVIDER=smtp

# SMTP. All three of HOST/USER/PASS must be set together, or all left empty —
# a partial configuration is an error in production and a warning in development.
SMTP_HOST=
SMTP_PORT=587
# Leave empty to auto-detect TLS (true for port 465, false otherwise).
# SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@hvault.local

# Gmail (EMAIL_PROVIDER=gmail). Use an App Password, not your account password:
# https://myaccount.google.com/apppasswords . Both must be set, or neither.
# GMAIL_USERNAME=
# GMAIL_PASSWORD=

# -----------------------------------------------------------------------------
# Backup / export
# -----------------------------------------------------------------------------
BACKUP_MAX_SIZE_MB=25
BACKUP_RETENTION_DAYS=30
EXPORT_MAX_SIZE_MB=25

# -----------------------------------------------------------------------------
# File Encryption tool
# -----------------------------------------------------------------------------
# Client-side size guardrail (MB, 1-1024) for the standalone File Encryption tool.
# The file is encrypted entirely in the browser and NEVER uploaded, so the server
# cannot enforce this — it is advertised to the client via GET /api/v1/config.
FILE_ENCRYPTION_MAX_SIZE_MB=100

# -----------------------------------------------------------------------------
# Audit
# -----------------------------------------------------------------------------
AUDIT_LOG_RETENTION_DAYS=365

# -----------------------------------------------------------------------------
# Feature flags
# -----------------------------------------------------------------------------
# Swagger UI (/api/docs) and the OpenAPI document (/api/v1/docs.json). Served
# automatically in development and test. Enabling it in production exposes
# UNAUTHENTICATED API docs — leave it off unless you mean it.
# ENABLE_SWAGGER=false

# Metrics endpoint token (min 16 chars). When set, GET /api/v1/metrics is exposed
# and requires a matching `x-metrics-token` header. Unset, the endpoint 404s.
# METRICS_TOKEN=
